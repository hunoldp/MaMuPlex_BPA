cat > /cfs/klemming/scratch/p/phunold/BPA5/scripts/demux_exact_r1_barcode.py <<'EOF'
#!/usr/bin/env python3
import argparse
import gzip
import os

BARCODES = {
    "GTGATGCT": "H3K27m3",
    "CCTATAGC": "H3K27ac",
}

def gzopen(path, mode):
    return gzip.open(path, mode)

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--r1", required=True)
    ap.add_argument("--r2", required=True)
    ap.add_argument("--sample", required=True)
    ap.add_argument("--outdir", required=True)
    ap.add_argument("--summary", required=True)
    args = ap.parse_args()

    os.makedirs(args.outdir, exist_ok=True)
    os.makedirs(os.path.dirname(args.summary), exist_ok=True)

    counts = {name: 0 for name in BARCODES.values()}
    counts["unassigned"] = 0

    handles = {}
    for modality in list(BARCODES.values()) + ["unassigned"]:
        r1_out = os.path.join(args.outdir, f"{args.sample}_{modality}_R1.fastq.gz")
        r2_out = os.path.join(args.outdir, f"{args.sample}_{modality}_R2.fastq.gz")
        handles[modality] = (
            gzopen(r1_out, "wt"),
            gzopen(r2_out, "wt"),
        )

    with gzopen(args.r1, "rt") as f1, gzopen(args.r2, "rt") as f2:
        while True:
            h1 = f1.readline()
            if not h1:
                break
            s1 = f1.readline()
            p1 = f1.readline()
            q1 = f1.readline()

            h2 = f2.readline()
            s2 = f2.readline()
            p2 = f2.readline()
            q2 = f2.readline()

            bc = s1[:8]
            modality = BARCODES.get(bc, "unassigned")
            counts[modality] += 1

            out1, out2 = handles[modality]
            out1.write(h1); out1.write(s1); out1.write(p1); out1.write(q1)
            out2.write(h2); out2.write(s2); out2.write(p2); out2.write(q2)

    for out1, out2 in handles.values():
        out1.close()
        out2.close()

    with open(args.summary, "w") as out:
        out.write("sample\tmodality\tread_pairs\n")
        for modality in ["H3K27m3", "H3K27ac", "unassigned"]:
            out.write(f"{args.sample}\t{modality}\t{counts[modality]}\n")

if __name__ == "__main__":
    main()
EOF



