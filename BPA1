  zcat \"\$r1\" | awk 'NR%4==1{h=\$0} NR%4==2{s=substr(\$0,28)} NR%4==3{p=\$0} NR%4==0{q=substr(\$0,28); print h\"\\n\"s\"\\n\"p\"\\n\"q}' | gzip > \"\$prefix.__R1trim.fq.gz\"; \
